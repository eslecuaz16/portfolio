---
const experiences = [
  {
    company: 'minu',
    role: 'Front End Leader',
    period: 'feb. 2023 — actualidad',
    location: 'CDMX · Híbrido',
    desc: 'Liderando iniciativas frontend para nuevas funcionalidades web y mobile. Arquitectura de componentes Vue.js en colaboración con producto y diseño.',
    highlights: [
      'Arquitectura de componentes reutilizables con Vue 3 + Pinia',
      'Implementación de interfaces White Label multi-tenant',
      'Integración de SendGrid, CleverTap y Capacitor.js',
      'Optimización de flujos críticos y performance (Core Web Vitals)',
      'Metodología Scrum, ceremonies y sprint planning',
    ],
    badge: 'actual',
  },
  {
    company: 'Aloux',
    role: 'Desarrollador Front-End',
    period: 'oct. 2021 — ene. 2023',
    location: 'México · Remoto',
    desc: 'Desarrollo y entrega de soluciones frontend personalizadas para clientes: desde definición técnica hasta implementación y QA.',
    highlights: [
      'Aplicaciones web con Vue.js, Nuxt.js y Vuetify',
      'Interfaces centradas en UX, accesibilidad y rendimiento',
      'Integración backend con Node.js y Firebase',
      'Comunicación directa con clientes para traducir negocio en código',
    ],
    badge: null,
  },
];
---
<section class="section" id="experiencia" style="background:var(--bg2)">
  <div class="container">
    <div class="reveal">
      <p class="eyebrow">// 04 — Experiencia</p>
      <h2 class="section-title">Trayectoria <span>profesional</span></h2>
      <p class="section-sub">Experiencia construyendo productos reales en equipos reales.</p>
    </div>

    <div class="exp-list">
      {experiences.map((e, i) => (
        <article class="exp-item reveal" style={`transition-delay:${i*100}ms`}>
          <div class="exp-marker" aria-hidden="true">
            <span class="exp-dot"></span>
            {i < experiences.length-1 && <span class="exp-line"></span>}
          </div>
          <div class="exp-card">
            <div class="exp-top">
              <div>
                <h3 class="exp-role">{e.role}</h3>
                <p class="exp-company">
                  {e.company}
                  {e.badge && <span class="exp-badge">{e.badge}</span>}
                </p>
              </div>
              <div class="exp-meta">
                <span>{e.period}</span>
                <span>{e.location}</span>
              </div>
            </div>
            <p class="exp-desc">{e.desc}</p>
            <ul class="exp-highlights">
              {e.highlights.map(h => <li>{h}</li>)}
            </ul>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.exp-list { display: flex; flex-direction: column; gap: 0; margin-top: .5rem; }

.exp-item {
  display: grid;
  grid-template-columns: 28px 1fr;
  column-gap: 1.5rem;
  align-items: stretch;
}
.exp-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 1.75rem;
}
.exp-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: var(--accent);
  border: 2px solid var(--bg2);
  box-shadow: 0 0 0 2px rgba(74,242,161,.3);
  flex-shrink: 0;
}
.exp-line {
  width: 1px;
  flex: 1;
  min-height: 2rem;
  background: linear-gradient(to bottom, rgba(74,242,161,.2), rgba(74,242,161,.03));
  margin-top: 6px;
}

.exp-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 1.6rem 1.75rem;
  margin-bottom: 1.5rem;
  transition: border-color .3s;
}
.exp-card:hover { border-color: rgba(74,242,161,.2); }

.exp-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 1rem;
  margin-bottom: .875rem;
}
.exp-role    { font-size: 1.05rem; font-weight: 700; letter-spacing: -.02em; margin-bottom: .15rem; }
.exp-company {
  font-family: var(--mono);
  font-size: .78rem;
  color: var(--muted);
  display: flex;
  align-items: center;
  gap: .5rem;
}
.exp-badge {
  font-size: .58rem;
  letter-spacing: .1em;
  text-transform: uppercase;
  padding: .18rem .55rem;
  background: var(--accent-dim);
  color: var(--accent);
  border: 1px solid rgba(74,242,161,.2);
  border-radius: 3px;
}
.exp-meta {
  display: flex;
  flex-direction: column;
  gap: .2rem;
  font-family: var(--mono);
  font-size: .7rem;
  color: var(--muted);
  text-align: right;
  white-space: nowrap;
  flex-shrink: 0;
}
.exp-desc {
  font-family: var(--mono);
  font-size: .78rem;
  color: var(--muted);
  line-height: 1.8;
  margin-bottom: 1rem;
}
.exp-highlights {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: .4rem;
  padding-left: .5rem;
  border-left: 1px solid rgba(74,242,161,.12);
}
.exp-highlights li {
  font-family: var(--mono);
  font-size: .73rem;
  color: var(--muted);
  padding-left: .75rem;
  position: relative;
}
.exp-highlights li::before {
  content: '→';
  position: absolute;
  left: -.5rem;
  color: var(--accent);
  opacity: .5;
}

@media (max-width: 640px) {
  .exp-item { grid-template-columns: 1fr; }
  .exp-marker { display: none; }
  .exp-top { flex-direction: column; }
  .exp-meta { text-align: left; flex-direction: row; flex-wrap: wrap; gap: .5rem; }
}
</style>