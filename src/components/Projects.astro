---
import type { Locale } from '../i18n/ui';
import { getUi } from '../i18n/ui';

interface ProjectBase {
  stack: string[];
  codeHtml: string;
  filename: string;
  liveUrl: string;
  githubUrl: string;
}

const projectsBase: ProjectBase[] = [
  {
    stack: ['Vue 3', 'Vuetify', 'Pinia', 'Firebase'],
    filename: 'stores/iam.ts',
    liveUrl: '#',
    githubUrl: '#',
    codeHtml: [
      '<span class="kw">const</span><span class="prop"> useIAM</span> <span class="op">=</span> <span class="fn">defineStore</span><span class="op">(</span>',
      '<span class="str">&nbsp;&nbsp;\'iam\'</span><span class="op">,</span> <span class="cm">// Pinia store</span>',
      '<span class="op">&nbsp;&nbsp;() =&gt; ({</span>',
      '<span class="prop">&nbsp;&nbsp;&nbsp;&nbsp;user</span><span class="op">:</span> <span class="fn">ref</span><span class="op">&lt;</span><span class="tp">User | null</span><span class="op">&gt;(</span><span class="num">null</span><span class="op">),</span>',
      '<span class="prop">&nbsp;&nbsp;&nbsp;&nbsp;perms</span><span class="op">:</span> <span class="fn">ref</span><span class="op">&lt;</span><span class="tp">string[]</span><span class="op">&gt;([])</span>',
      '<span class="op">&nbsp;&nbsp;})</span>',
      '<span class="op">)</span>',
    ].join('<br>'),
  },
  {
    stack: ['Vue', 'Vuetify', 'jsPDF', 'html2canvas'],
    filename: 'utils/exportPDF.ts',
    liveUrl: '#',
    githubUrl: '#',
    codeHtml: [
      '<span class="kw">async function</span><span class="fn"> exportPDF</span><span class="op">() {</span>',
      '<span class="kw">&nbsp;&nbsp;const</span><span class="prop"> doc</span> <span class="op">=</span> <span class="kw">new</span> <span class="fn">jsPDF</span><span class="op">()</span>',
      '<span class="kw">&nbsp;&nbsp;await</span> <span class="fn">html2canvas</span><span class="op">(</span><span class="prop">el</span><span class="op">)</span>',
      '<span class="cm">&nbsp;&nbsp;// anti-duplicate page logic</span>',
      '<span class="prop">&nbsp;&nbsp;doc</span><span class="op">.</span><span class="fn">save</span><span class="op">(</span>',
      '<span class="str">&nbsp;&nbsp;&nbsp;&nbsp;`orden-$&#123;id&#125;.pdf`</span>',
      '<span class="op">&nbsp;&nbsp;)</span>',
      '<span class="op">}</span>',
    ].join('<br>'),
  },
  {
    stack: ['Astro', 'TypeScript', 'CSS', 'Formspree'],
    filename: 'scripts/reveal.ts',
    liveUrl: '#',
    githubUrl: 'https://github.com/eslecuaz16/portfolio',
    codeHtml: [
      '<span class="kw">export function</span><span class="fn"> initReveal</span><span class="op">() {</span>',
      '<span class="kw">&nbsp;&nbsp;const</span><span class="prop"> obs</span> <span class="op">=</span> <span class="kw">new</span>',
      '<span class="fn">&nbsp;&nbsp;&nbsp;&nbsp;IntersectionObserver</span><span class="op">(</span>',
      '<span class="op">&nbsp;&nbsp;&nbsp;&nbsp;([</span><span class="prop">entry</span><span class="op">]) =&gt; {</span>',
      '<span class="kw">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;if</span> <span class="op">(</span><span class="prop">entry</span><span class="op">.</span><span class="prop">isIntersecting</span><span class="op">)</span>',
      '<span class="prop">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;el</span><span class="op">.</span><span class="fn">classList</span><span class="op">.</span><span class="fn">add</span><span class="op">(</span><span class="str">\'visible\'</span><span class="op">)</span>',
      '<span class="op">&nbsp;&nbsp;})</span>',
      '<span class="op">}</span>',
    ].join('<br>'),
  },
];

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = getUi(locale);
const cards = t.projects.cards;
const demoLabel = locale === 'es' ? 'Ver demo de' : 'View demo of';
const codeLabel = locale === 'es' ? 'Ver código de' : 'View code for';
---

<section class="section" id="proyectos" style="background:var(--bg2)">
  <div class="container">
    <div class="reveal">
      <p class="eyebrow">{t.projects.eyebrow}</p>
      <h2 class="section-title">{t.projects.title}<span>{t.projects.titleAccent}</span></h2>
      <p class="section-sub">{t.projects.sub}</p>
    </div>

    <div class="proj-grid">
      {projectsBase.map((p, i) => {
        const meta = cards[i];
        return (
        <article class="proj-card reveal" style={`transition-delay:${i * 100}ms`}>

          <div class="proj-header">
            <span class="proj-num">{meta.num}</span>
            <div class="proj-links">
              <a href={p.liveUrl} class="proj-link" aria-label={`${demoLabel} ${meta.title}`}>{t.projects.live}</a>
              <a href={p.githubUrl} class="proj-link" aria-label={`${codeLabel} ${meta.title}`}>{t.projects.github}</a>
            </div>
          </div>

          <div class="proj-code-preview">
            <div class="code-bar" style="padding:.45rem .85rem">
              <span class="dot dot-r" style="width:8px;height:8px"></span>
              <span class="dot dot-y" style="width:8px;height:8px"></span>
              <span class="dot dot-g" style="width:8px;height:8px"></span>
              <span class="code-fname">{p.filename}</span>
            </div>
            <div class="code-body" style="padding:.9rem 1.1rem;font-size:.69rem" set:html={p.codeHtml} />
          </div>

          <div class="proj-body">
            <h3 class="proj-title">{meta.title}</h3>
            <p class="proj-desc">{meta.desc}</p>
            <div class="proj-tags">
              {p.stack.map((tag, ti) => (
                <span class={ti % 2 === 0 ? 'pill' : 'pill blue'}>{tag}</span>
              ))}
            </div>
          </div>

        </article>
      );
      })}
    </div>
  </div>
</section>

<style>
.proj-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
  gap: 1.5rem;
}
.proj-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color .3s, transform .3s;
}
.proj-card:hover {
  border-color: rgba(79, 140, 255, .28);
  transform: translateY(-5px);
}
.proj-card:hover .proj-code-preview {
  opacity: 1;
  transform: translateY(0);
}
.proj-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.4rem 1.6rem 1rem;
}
.proj-num {
  font-family: var(--mono);
  font-size: .62rem;
  color: var(--accent);
  opacity: .5;
  letter-spacing: .15em;
}
.proj-links { display: flex; gap: .75rem; }
.proj-link {
  font-family: var(--mono);
  font-size: .62rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: .08em;
  transition: color .2s;
}
.proj-link:hover { color: var(--accent); }
.proj-code-preview {
  margin: 0 1.25rem;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  overflow: hidden;
  opacity: .65;
  transform: translateY(4px);
  transition: opacity .3s, transform .3s;
}
.proj-body {
  padding: 1.25rem 1.6rem 1.6rem;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: .75rem;
}
.proj-title {
  font-size: 1.12rem;
  font-weight: 700;
  letter-spacing: -.02em;
}
.proj-desc {
  font-family: var(--mono);
  font-size: .74rem;
  color: var(--muted);
  line-height: 1.75;
  flex: 1;
}
.proj-tags { display: flex; flex-wrap: wrap; gap: .4rem; }
</style>
