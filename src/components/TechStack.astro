---
import type { Locale } from '../i18n/ui';
import { getUi } from '../i18n/ui';

const skills = [
  { name: 'Vue 3 / Nuxt',    pct: 92, color: 'green' },
  { name: 'TypeScript',       pct: 85, color: 'blue'  },
  { name: 'Astro',            pct: 88, color: 'green' },
  { name: 'TailwindCSS',      pct: 90, color: 'blue'  },
  { name: 'CSS / SCSS',       pct: 94, color: 'green' },
  { name: 'Vuetify',          pct: 88, color: 'blue'  },
  { name: 'Pinia / Vuex',     pct: 86, color: 'green' },
  { name: 'Firebase',         pct: 80, color: 'blue'  },
  { name: 'Git / GitHub',     pct: 91, color: 'green' },
  { name: 'Figma',            pct: 78, color: 'blue'  },
];

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = getUi(locale);
---

<section class="section" id="tecnologias">
  <div class="container">
    <div class="reveal">
      <p class="eyebrow">{t.tech.eyebrow}</p>
      <h2 class="section-title">{t.tech.title}<span>{t.tech.titleAccent}</span></h2>
      <p class="section-sub">{t.tech.sub}</p>
    </div>

    <div class="stack-layout">
      <div class="stack-bars reveal" style="transition-delay:.1s">
        {skills.map((s, i) => (
          <div class="skill-row" style={`transition-delay:${i*60}ms`}>
            <div class="skill-meta">
              <span class="skill-name">{s.name}</span>
              <span class="skill-pct">{s.pct}%</span>
            </div>
            <div class="skill-track">
              <div
                class={`skill-fill skill-fill--${s.color}`}
                data-w={s.pct}
                role="progressbar"
                aria-valuenow={s.pct}
                aria-valuemin={0}
                aria-valuemax={100}
                aria-label={`${s.name}: ${s.pct}%`}
              ></div>
            </div>
          </div>
        ))}
      </div>

      <div class="stack-code reveal" style="transition-delay:.15s">
        <div class="code-window">
          <div class="code-bar">
            <span class="dot dot-r"></span>
            <span class="dot dot-y"></span>
            <span class="dot dot-g"></span>
            <span class="code-fname">composables/useReveal.ts</span>
            <span class="live-badge">● live</span>
          </div>
          <div class="code-body">
<span class="cm">{t.tech.codeComment}</span><br>
<span class="kw">import</span> <span class="op">{</span> <span class="fn">ref</span><span class="op">,</span> <span class="fn">onMounted</span> <span class="op">}</span> <span class="kw">from</span> <span class="str">'vue'</span><br>
<br>
<span class="kw">export function</span> <span class="fn">useReveal</span><span class="op">&lt;</span><br>
&nbsp;&nbsp;<span class="tp">T</span> <span class="kw">extends</span> <span class="tp">HTMLElement</span><br>
<span class="op">&gt;() {</span><br>
&nbsp;&nbsp;<span class="kw">const</span> <span class="prop">el</span>  <span class="op">=</span> <span class="fn">ref</span><span class="op">&lt;</span><span class="tp">T | null</span><span class="op">&gt;(</span><span class="kw">null</span><span class="op">)</span><br>
&nbsp;&nbsp;<span class="kw">const</span> <span class="prop">vis</span> <span class="op">=</span> <span class="fn">ref</span><span class="op">(</span><span class="kw">false</span><span class="op">)</span><br>
<br>
&nbsp;&nbsp;<span class="fn">onMounted</span><span class="op">(() => {</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="kw">const</span> <span class="prop">obs</span> <span class="op">=</span> <span class="kw">new</span> <span class="fn">IntersectionObserver</span><span class="op">(</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="op">([</span><span class="prop">entry</span><span class="op">]) => {</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="kw">if</span> <span class="op">(</span><span class="prop">entry</span><span class="op">.</span><span class="prop">isIntersecting</span><span class="op">)</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="prop">vis</span><span class="op">.</span><span class="prop">value</span> <span class="op">=</span> <span class="kw">true</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="op">},</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="op">{</span> <span class="prop">threshold</span><span class="op">:</span> <span class="num">0.15</span> <span class="op">}</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="op">)</span><br>
&nbsp;&nbsp;&nbsp;&nbsp;<span class="kw">if</span> <span class="op">(</span><span class="prop">el</span><span class="op">.</span><span class="prop">value</span><span class="op">)</span> <span class="prop">obs</span><span class="op">.</span><span class="fn">observe</span><span class="op">(</span><span class="prop">el</span><span class="op">.</span><span class="prop">value</span><span class="op">)</span><br>
&nbsp;&nbsp;<span class="op">})</span><br>
<br>
&nbsp;&nbsp;<span class="kw">return</span> <span class="op">{</span> <span class="prop">el</span><span class="op">,</span> <span class="prop">vis</span> <span class="op">}</span><br>
<span class="op">}</span><br>
<br>
<span class="kw">export default</span> <span class="fn">useReveal</span><span class="type-cursor"></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.live-badge {
  font-family: var(--mono);
  font-size: .62rem;
  color: var(--accent);
  letter-spacing: .08em;
  margin-left: auto;
  animation: pulse-opacity 2s ease infinite;
}
@keyframes pulse-opacity { 0%,100%{opacity:1} 50%{opacity:.45} }

.stack-layout {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 4rem;
  align-items: start;
}

.stack-bars { display: flex; flex-direction: column; gap: .85rem; }

.skill-row { display: flex; flex-direction: column; gap: .38rem; }
.skill-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.skill-name { font-family: var(--mono); font-size: .78rem; color: var(--text); }
.skill-pct  { font-family: var(--mono); font-size: .65rem; color: var(--muted); }
.skill-track {
  height: 2px;
  background: rgba(245, 247, 250, .06);
  border-radius: 2px;
  overflow: hidden;
}
.skill-fill {
  height: 100%;
  border-radius: 2px;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .95s cubic-bezier(.23,1,.32,1);
  will-change: transform;
}
.skill-fill.animated { transform: scaleX(1); }
.skill-fill--green { background: linear-gradient(90deg, var(--accent), var(--accent-purple)); }
.skill-fill--blue  { background: linear-gradient(90deg, var(--accent2), var(--accent)); }

.stack-code { position: sticky; top: 5rem; }
.stack-code .code-window { box-shadow: 0 20px 60px rgba(0,0,0,.5); }

@media (max-width: 900px) {
  .stack-layout { grid-template-columns: 1fr; }
  .stack-code { display: none; }
}
</style>

<script>
const barObs = new IntersectionObserver(function(entries) {
  entries.forEach(function(e) {
    if (e.isIntersecting) {
      e.target.classList.add('animated');
      barObs.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
document.querySelectorAll('.skill-fill').forEach(function(b) { barObs.observe(b); });
</script>
