<nav class="nav" role="navigation" aria-label="Navegación principal">
  <div class="container nav-inner">
    <a href="#hero" class="nav-logo" aria-label="Inicio">
      <span class="logo-bracket">[</span>eslecuaz<span class="logo-dot">.</span>dev<span class="logo-bracket">]</span>
    </a>
    <ul class="nav-links">
      <li><a href="#servicios">servicios</a></li>
      <li><a href="#proyectos">proyectos</a></li>
      <li><a href="#experiencia">experiencia</a></li>
      <li><a href="#contacto" class="nav-cta">contrátame →</a></li>
    </ul>
  </div>
</nav>

<style>
.nav {
  position: fixed; top: 0; left: 0; right: 0;
  z-index: 200;
  padding: 1rem 0;
  background: rgba(6,8,12,.8);
  backdrop-filter: blur(18px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.nav-logo {
  font-family: var(--mono);
  font-size: .88rem;
  font-weight: 700;
  color: var(--text);
  text-decoration: none;
  letter-spacing: -.01em;
  transition: color .2s;
}
.logo-bracket { color: var(--accent); }
.logo-dot     { color: var(--muted); }
.nav-logo:hover { color: var(--accent); }

.nav-links {
  display: flex;
  gap: 2rem;
  list-style: none;
  align-items: center;
}
.nav-links a {
  font-family: var(--mono);
  font-size: .7rem;
  letter-spacing: .1em;
  color: var(--muted);
  text-decoration: none;
  transition: color .2s;
}
.nav-links a:hover { color: var(--text); }

.nav-cta {
  padding: .5rem 1.2rem;
  background: transparent;
  border: 1px solid rgba(74,242,161,.3) !important;
  color: var(--accent) !important;
  border-radius: var(--radius);
  transition: background .2s, transform .2s !important;
}
.nav-cta:hover {
  background: var(--accent-dim) !important;
  transform: translateY(-1px);
}

@media (max-width: 640px) {
  .nav-links li:not(:last-child) { display: none; }
}
</style>