---
const services = [
  {
    num: '01',
    title: 'Landing pages',
    desc: 'Páginas de conversión rápidas, bien estructuradas y optimizadas para SEO y Core Web Vitals.',
    icon: '⚡',
  },
  {
    num: '02',
    title: 'Sitios web de negocio',
    desc: 'Presencia digital profesional, multi-sección, responsive y conectada a analíticas.',
    icon: '🌐',
  },
  {
    num: '03',
    title: 'Aplicaciones web',
    desc: 'Dashboards, gestores y flujos complejos con Vue.js, arquitectura escalable y buena DX.',
    icon: '🛠',
  },
  {
    num: '04',
    title: 'UX & Performance',
    desc: 'Auditoría, optimización de carga, accesibilidad y mejora de experiencia de usuario.',
    icon: '📊',
  },
];
---
<section class="section" id="servicios">
  <div class="container">
    <div class="reveal">
      <p class="eyebrow">// 01 — Servicios</p>
      <h2 class="section-title">En qué <span>puedo ayudarte</span></h2>
      <p class="section-sub">Soluciones frontend que conectan tu negocio con tus clientes. Sin relleno, sin templates, todo a medida.</p>
    </div>

    <div class="srv-grid">
      {services.map((s, i) => (
        <article class="srv-card reveal" style={`transition-delay:${i*80}ms`}>
          <div class="srv-num" aria-hidden="true">{s.num}</div>
          <div class="srv-icon" aria-hidden="true">{s.icon}</div>
          <h3 class="srv-title">{s.title}</h3>
          <p class="srv-desc">{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.srv-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}
.srv-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem 1.75rem;
  position: relative;
  overflow: hidden;
  transition: border-color .3s, transform .3s;
}
.srv-card:hover { border-color: rgba(74,242,161,.25); transform: translateY(-4px); }
.srv-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(74,242,161,.04) 0%, transparent 60%);
  opacity: 0;
  transition: opacity .3s;
}
.srv-card:hover::after { opacity: 1; }

.srv-num {
  font-family: var(--mono);
  font-size: .65rem;
  color: var(--accent);
  letter-spacing: .15em;
  opacity: .5;
  margin-bottom: 1.25rem;
}
.srv-icon {
  font-size: 1.5rem;
  margin-bottom: 1rem;
  line-height: 1;
}
.srv-title {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -.02em;
  margin-bottom: .6rem;
}
.srv-desc {
  font-family: var(--mono);
  font-size: .75rem;
  color: var(--muted);
  line-height: 1.8;
}
/* ghost num bg */
.srv-card::before {
  content: attr(data-n);
  position: absolute;
  right: 1rem; bottom: .5rem;
  font-size: 4.5rem;
  font-weight: 800;
  color: rgba(255,255,255,.025);
  pointer-events: none;
  font-family: var(--sans);
  line-height: 1;
}
</style>