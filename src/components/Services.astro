---
import type { Locale } from '../i18n/ui';
import { getUi } from '../i18n/ui';

interface Props {
  locale?: Locale;
}

const { locale = 'es' } = Astro.props;
const t = getUi(locale);
const services = t.services.items;
---
<section class="section" id="servicios">
  <div class="container">
    <div class="reveal">
      <p class="eyebrow">{t.services.eyebrow}</p>
      <h2 class="section-title">{t.services.title}<span>{t.services.titleAccent}</span></h2>
      <p class="section-sub">{t.services.sub}</p>
    </div>

    <div class="srv-grid">
      {services.map((s, i) => (
        <article class="srv-card reveal" style={`transition-delay:${i*80}ms`}>
          <div class="srv-num" aria-hidden="true">{s.num}</div>
          <div class="srv-icon" aria-hidden="true">{s.icon}</div>
          <h3 class="srv-title">{s.title}</h3>
          <p class="srv-desc">{s.desc}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
.srv-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 1.25rem;
}
.srv-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 2rem 1.75rem;
  position: relative;
  overflow: hidden;
  transition: border-color .3s, transform .3s;
}
.srv-card:hover { border-color: rgba(79, 140, 255, .26); transform: translateY(-4px); }
.srv-card::after {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(79, 140, 255, .05) 0%, transparent 60%);
  opacity: 0;
  transition: opacity .3s;
}
.srv-card:hover::after { opacity: 1; }

.srv-num {
  font-family: var(--mono);
  font-size: .65rem;
  color: var(--accent);
  letter-spacing: .15em;
  opacity: .5;
  margin-bottom: 1.25rem;
}
.srv-icon {
  font-size: 1.5rem;
  margin-bottom: 1rem;
  line-height: 1;
}
.srv-title {
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: -.02em;
  margin-bottom: .6rem;
}
.srv-desc {
  font-family: var(--mono);
  font-size: .75rem;
  color: var(--muted);
  line-height: 1.8;
}
.srv-card::before {
  content: attr(data-n);
  position: absolute;
  right: 1rem; bottom: .5rem;
  font-size: 4.5rem;
  font-weight: 800;
  color: rgba(255,255,255,.025);
  pointer-events: none;
  font-family: var(--sans);
  line-height: 1;
}
</style>
